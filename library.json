{
  "name": "pioTFLite",
  "version": "0.0.1",
  "build": {
    "includeDir": ".",
    "srcDir": "tensorflow",
    "extraScript": "extra_script.py",
    "srcFilter": [
      "-<*>",
      "+<lite/core/api/flatbuffer_conversions.cc>",
      "+<lite/core/c/common.cc>",
      "+<lite/kernels/internal/common.cc>",
      "+<lite/kernels/internal/portable_tensor_utils.cc>",
      "+<lite/kernels/internal/quantization_util.cc>",
      "+<lite/kernels/internal/tensor_ctypes.cc>",
      "+<lite/kernels/kernel_util.cc>",
      "+<lite/micro/arena_allocator/non_persistent_arena_buffer_allocator.cc>",
      "+<lite/micro/arena_allocator/persistent_arena_buffer_allocator.cc>",
      "+<lite/micro/arena_allocator/single_arena_buffer_allocator.cc>",
      "+<lite/micro/debug_log.cc>",
      "+<lite/micro/flatbuffer_utils.cc>",
      "+<lite/micro/memory_helpers.cc>",
      "+<lite/micro/memory_planner/greedy_memory_planner.cc>",
      "+<lite/micro/memory_planner/linear_memory_planner.cc>",
      "+<lite/micro/micro_allocation_info.cc>",
      "+<lite/micro/micro_allocator.cc>",
      "+<lite/micro/micro_context.cc>",
      "+<lite/micro/micro_interpreter.cc>",
      "+<lite/micro/micro_interpreter_context.cc>",
      "+<lite/micro/micro_interpreter_graph.cc>",
      "+<lite/micro/micro_log.cc>",
      "+<lite/micro/micro_op_resolver.cc>",
      "+<lite/micro/micro_resource_variable.cc>",
      "+<lite/micro/micro_time.cc>",
      "+<lite/micro/micro_utils.cc>",
      "+<lite/micro/tflite_bridge/flatbuffer_conversions_bridge.cc>",
      "+<lite/micro/tflite_bridge/micro_error_reporter.cc>",
      "+<lite/micro/kernels/activations.cc>",
      "+<lite/micro/kernels/activations_common.cc>",
      "+<lite/micro/kernels/fully_connected.cc>",
      "+<lite/micro/kernels/fully_connected_common.cc>",
      "+<lite/micro/kernels/kernel_util.cc>",
      "+<lite/micro/kernels/logistic.cc>",
      "+<lite/micro/kernels/logistic_common.cc>",
      "+<lite/micro/kernels/quantize.cc>",
      "+<lite/micro/kernels/quantize_common.cc>",
      "+<lite/micro/kernels/reshape.cc>",
      "+<lite/micro/kernels/reshape_common.cc>",
      "+<compiler/mlir/lite/core/api/error_reporter.cc>",
      "+<compiler/mlir/lite/schema/schema_utils.cc>"
    ],
    "flags": [
      "-DTF_LITE_STATIC_MEMORY",
      "-Ithird_party/flatbuffers/include",
      "-Ithird_party/flatbuffers",
      "-Ithird_party/gemmlowp",
      "-Ithird_party/ruy"
    ]
  }
}
